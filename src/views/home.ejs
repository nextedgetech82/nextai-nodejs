<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/css/style.css" />
  </head>
  <body class="admin-shell">
    <%- include("partials/admin-shell-top", { activePage: "home", pageTitle: title }) %>
      <div class="row justify-content-center min-vh-75 align-items-center">
        <div class="col-12 col-xl-8">
          <div class="card shadow-lg border-0 hero-card overflow-hidden">
            <div class="card-body p-4 p-md-5">
              <p class="eyebrow">Registry Admin</p>
              <h1 class="display-4 mb-3">Customer Management</h1>
              <p class="hero-copy mb-4">
                Manage customers, API keys, and token purchases from the same Node.js project.
              </p>
              <div class="d-flex gap-2 flex-wrap">
                <a class="btn btn-primary btn-lg px-4 rounded-pill" href="/admin/customers">Customers</a>
                <a class="btn btn-outline-primary btn-lg px-4 rounded-pill" href="/admin/customers/new">Add Customer</a>
              </div>
            </div>
          </div>
        </div>
      </div>
    <%- include("partials/admin-shell-bottom") %>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>
