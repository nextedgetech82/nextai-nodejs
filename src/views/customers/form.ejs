<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/css/style.css" />
  </head>
  <body class="admin-shell">
    <%- include("../partials/admin-shell-top", { activePage: "customer-form", pageTitle: title }) %>
      <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-end gap-3 mb-4">
        <div>
          <p class="eyebrow mb-2">Registry Admin</p>
          <h1 class="mb-0"><%= mode === "edit" ? "Edit Customer" : "Add Customer" %></h1>
        </div>
        <div class="d-flex gap-2 flex-wrap">
          <a class="btn btn-outline-secondary rounded-pill px-4" href="/admin/customers">Back</a>
          <% if (mode === "edit") { %>
            <a class="btn btn-primary rounded-pill px-4" href="/admin/customers/<%= customer.customer_id %>/tokens">Manage Tokens</a>
          <% } %>
        </div>
      </div>

      <section class="card border-0 shadow-sm panel">
        <div class="card-body p-4">
          <form class="customer-form" method="post" action="<%= mode === 'edit' ? '/admin/customers/' + customer.customer_id : '/admin/customers' %>">
            <div class="row g-4">
              <div class="col-md-6">
                <label class="form-label">Customer ID</label>
                <input class="form-control premium-input" name="customer_id" value="<%= customer.customer_id || '' %>" <%= mode === "edit" ? "readonly" : "required" %> />
              </div>
              <div class="col-md-6">
                <label class="form-label">Customer Name</label>
                <input class="form-control premium-input" name="customer_name" value="<%= customer.customer_name || '' %>" required />
              </div>
              <div class="col-md-6">
                <label class="form-label">Customer Code</label>
                <input class="form-control premium-input" name="customer_code" value="<%= customer.customer_code || '' %>" />
              </div>
              <div class="col-md-6">
                <label class="form-label">Subscription Plan</label>
                <select class="form-select premium-input" name="subscription_plan">
                <% ["basic", "professional", "enterprise"].forEach((plan) => { %>
                  <option value="<%= plan %>" <%= customer.subscription_plan === plan ? "selected" : "" %>><%= plan %></option>
                <% }) %>
                </select>
              </div>
              <div class="col-md-6">
                <label class="form-label">Status</label>
                <select class="form-select premium-input" name="status">
                <% ["active", "inactive"].forEach((status) => { %>
                  <option value="<%= status %>" <%= customer.status === status ? "selected" : "" %>><%= status %></option>
                <% }) %>
                </select>
              </div>
              <div class="col-md-6">
                <label class="form-label">Main DB Type</label>
                <select class="form-select premium-input" name="main_db_type">
                <option value="mssql" <%= customer.main_db_type === "mssql" ? "selected" : "" %>>mssql</option>
                </select>
              </div>
              <div class="col-md-6">
                <label class="form-label">Main DB Host</label>
                <input class="form-control premium-input" name="main_db_host" value="<%= customer.main_db_host || '' %>" required />
              </div>
              <div class="col-md-6">
                <label class="form-label">Main DB Port</label>
                <input class="form-control premium-input" name="main_db_port" type="number" value="<%= customer.main_db_port || 1433 %>" required />
              </div>
              <div class="col-md-6">
                <label class="form-label">Main DB Name</label>
                <input class="form-control premium-input" name="main_db_name" value="<%= customer.main_db_name || '' %>" required />
              </div>
              <div class="col-md-6">
                <label class="form-label">Main DB User</label>
                <input class="form-control premium-input" name="main_db_user" value="<%= customer.main_db_user || '' %>" required />
              </div>
              <div class="col-12">
                <label class="form-label">Main DB Password</label>
                <div class="input-group password-group">
                  <input
                    class="form-control premium-input"
                    id="main_db_password"
                    name="main_db_password"
                    type="password"
                    value="<%= customer.main_db_password || '' %>"
                    required
                  />
                  <button
                    class="btn btn-outline-secondary password-toggle"
                    type="button"
                    data-target="main_db_password"
                    aria-label="Show password"
                    aria-pressed="false"
                    title="Show password"
                  >
                    <span class="password-toggle-icon" aria-hidden="true">👁</span>
                  </button>
                </div>
              </div>
              <div class="col-12">
                <div class="form-check premium-check">
                  <input class="form-check-input" type="checkbox" name="main_db_encrypt" id="main_db_encrypt" <%= customer.main_db_encrypt ? "checked" : "" %> />
                  <label class="form-check-label" for="main_db_encrypt">Use Encryption</label>
                </div>
              </div>
            </div>

            <div class="d-flex gap-2 flex-wrap mt-4">
              <a class="btn btn-outline-secondary rounded-pill px-4" href="/admin/customers">Cancel</a>
              <button class="btn btn-primary rounded-pill px-4" type="submit"><%= mode === "edit" ? "Update Customer" : "Create Customer" %></button>
            </div>
          </form>
        </div>
      </section>
    <%- include("../partials/admin-shell-bottom") %>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
      document.addEventListener("click", (event) => {
        const button = event.target.closest(".password-toggle");
        if (!button) {
          return;
        }

        const target = document.getElementById(button.dataset.target);
        if (!target) {
          return;
        }

        const isHidden = target.getAttribute("type") === "password";
        target.setAttribute("type", isHidden ? "text" : "password");
        button.querySelector(".password-toggle-icon").textContent = isHidden ? "🙈" : "👁";
        button.setAttribute("aria-label", isHidden ? "Hide password" : "Show password");
        button.setAttribute("aria-pressed", String(isHidden));
        button.setAttribute("title", isHidden ? "Hide password" : "Show password");
      });
    </script>
  </body>
</html>
