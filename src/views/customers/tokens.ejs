<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/css/style.css" />
  </head>
  <body class="admin-shell">
    <% const selectedBatch = batches.find((batch) => String(batch.id) === String(editingBatchId)) || null; %>
    <%- include("../partials/admin-shell-top", { activePage: "tokens", pageTitle: title }) %>
      <div class="token-header card border-0 shadow-sm mb-4">
        <div class="card-body p-3 p-lg-4">
          <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3">
            <div class="token-header-copy">
              <div class="token-header-meta">
                <span class="token-header-chip">Customer Workspace</span>
                <span class="token-header-id">ID: <%= customer.customer_id %></span>
              </div>
              <h1 class="token-header-title mb-1"><%= customer.customer_name %></h1>
              <p class="token-header-text mb-0">Manage API key, token balance, and purchase batches from one place.</p>
            </div>
            <div class="d-flex gap-2 flex-wrap">
              <a class="btn btn-outline-secondary rounded-pill px-4" href="/admin/customers">Customers</a>
              <a class="btn btn-outline-dark rounded-pill px-4" href="/admin/customers/<%= customer.customer_id %>/edit">Edit Customer</a>
            </div>
          </div>
        </div>
      </div>

      <section class="row g-3 mb-4">
        <div class="col-6 col-xl-3">
          <article class="card border-0 stat-card h-100">
            <div class="card-body">
              <span class="stat-label">Allocated</span>
              <strong><%= apiKeyRow.allocated_tokens || 0 %></strong>
            </div>
          </article>
        </div>
        <div class="col-6 col-xl-3">
          <article class="card border-0 stat-card h-100">
            <div class="card-body">
              <span class="stat-label">Remaining</span>
              <strong><%= apiKeyRow.tokens_remaining || 0 %></strong>
            </div>
          </article>
        </div>
        <div class="col-6 col-xl-3">
          <article class="card border-0 stat-card h-100">
            <div class="card-body">
              <span class="stat-label">Purchased</span>
              <strong><%= apiKeyRow.total_tokens_purchased || 0 %></strong>
            </div>
          </article>
        </div>
        <div class="col-6 col-xl-3">
          <article class="card border-0 stat-card h-100">
            <div class="card-body">
              <span class="stat-label">Paid</span>
              <strong><%= apiKeyRow.payment_amount || 0 %></strong>
            </div>
          </article>
        </div>
      </section>

      <div class="row g-4 mb-4">
        <div class="col-xl-5">
          <section class="card border-0 shadow-sm panel h-100">
            <div class="card-body p-4">
              <h2 class="section-title">API Key Setup</h2>
              <form class="customer-form" method="post" action="/admin/customers/<%= customer.customer_id %>/api-key">
                <div class="row g-3">
                  <div class="col-12">
                    <label class="form-label">API Key</label>
                    <input class="form-control premium-input" name="api_key" value="<%= apiKeyRow.api_key || '' %>" placeholder="Leave blank to auto-generate on first save" />
                  </div>
                  <div class="col-md-6">
                    <label class="form-label">Provider</label>
                    <input class="form-control premium-input" name="api_provider" value="<%= apiKeyRow.api_provider || 'deepseek' %>" />
                  </div>
                  <div class="col-md-6">
                    <label class="form-label">Monthly Limit</label>
                    <input class="form-control premium-input" type="number" name="monthly_limit" value="<%= apiKeyRow.monthly_limit || 100000 %>" />
                  </div>
                  <div class="col-12">
                    <div class="form-check premium-check">
                      <input class="form-check-input" type="checkbox" name="is_active" id="is_active" <%= apiKeyRow.is_active ? "checked" : "" %> />
                      <label class="form-check-label" for="is_active">Active</label>
                    </div>
                  </div>
                </div>
                <div class="mt-4">
                  <button class="btn btn-primary rounded-pill px-4" type="submit">Save API Key Config</button>
                </div>
              </form>
            </div>
          </section>
        </div>

        <div class="col-xl-7">
          <section class="card border-0 shadow-sm panel h-100">
            <div class="card-body p-4">
              <h2 class="section-title"><%= selectedBatch ? "Edit Token Batch" : "Add Token Batch" %></h2>
              <form class="customer-form" method="post" action="/admin/customers/<%= customer.customer_id %>/tokens">
                <input type="hidden" name="id" value="<%= selectedBatch ? selectedBatch.id : '' %>" />
                <div class="row g-3">
                  <div class="col-md-6">
                    <label class="form-label">Batch ID</label>
                    <input class="form-control premium-input" name="batch_id" value="<%= selectedBatch ? selectedBatch.batch_id : '' %>" placeholder="Auto-generated if left blank" />
                  </div>
                  <div class="col-md-6">
                    <label class="form-label">Status</label>
                    <select class="form-select premium-input" name="status">
                      <% ["active", "depleted", "expired"].forEach((status) => { %>
                        <option value="<%= status %>" <%= selectedBatch && selectedBatch.status === status ? "selected" : (!selectedBatch && status === "active" ? "selected" : "") %>><%= status %></option>
                      <% }) %>
                    </select>
                  </div>
                  <div class="col-md-6">
                    <label class="form-label">Tokens Allocated</label>
                    <input class="form-control premium-input" type="number" name="tokens_allocated" value="<%= selectedBatch ? selectedBatch.tokens_allocated : '' %>" required />
                  </div>
                  <div class="col-md-6">
                    <label class="form-label">Tokens Remaining</label>
                    <input class="form-control premium-input" type="number" name="tokens_remaining" value="<%= selectedBatch ? selectedBatch.tokens_remaining : '' %>" />
                  </div>
                  <div class="col-md-6">
                    <label class="form-label">Purchase Amount</label>
                    <input class="form-control premium-input" type="number" step="0.01" name="purchase_amount" value="<%= selectedBatch ? selectedBatch.purchase_amount : '' %>" />
                  </div>
                  <div class="col-md-6">
                    <label class="form-label">Purchase Date</label>
                    <input
                      class="form-control premium-input"
                      id="purchase_date"
                      type="datetime-local"
                      name="purchase_date"
                      value="<%= selectedBatch && selectedBatch.purchase_date ? new Date(selectedBatch.purchase_date).toISOString().slice(0,16) : '' %>"
                    />
                  </div>
                  <div class="col-12">
                    <label class="form-label">Expiry Date</label>
                    <input
                      class="form-control premium-input"
                      id="expiry_date"
                      type="date"
                      value="<%= selectedBatch && selectedBatch.expiry_date ? new Date(selectedBatch.expiry_date).toISOString().slice(0,10) : '' %>"
                      readonly
                    />
                    <div class="field-note mt-2">Calculated automatically as one year after purchase date.</div>
                  </div>
                </div>
                <div class="d-flex gap-2 flex-wrap mt-4">
                  <% if (selectedBatch) { %>
                    <a class="btn btn-outline-secondary rounded-pill px-4" href="/admin/customers/<%= customer.customer_id %>/tokens">Cancel Edit</a>
                  <% } %>
                  <button class="btn btn-primary rounded-pill px-4" type="submit"><%= selectedBatch ? "Update Batch" : "Add Batch" %></button>
                </div>
              </form>
            </div>
          </section>
        </div>
      </div>

      <section class="card border-0 shadow-sm panel">
        <div class="card-body p-0">
          <div class="d-flex justify-content-between align-items-center px-4 pt-4">
            <h2 class="section-title mb-0">Token Batches</h2>
          </div>
          <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
            <thead>
              <tr>
                <th>ID</th>
                <th>Batch ID</th>
                <th>Allocated</th>
                <th>Remaining</th>
                <th>Purchase Amount</th>
                <th>Purchase Date</th>
                <th>Expiry Date</th>
                <th>Status</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>
              <% if (!batches.length) { %>
                <tr>
                  <td colspan="9" class="text-center text-muted py-5">No token batches found.</td>
                </tr>
              <% } %>
              <% batches.forEach((batch) => { %>
                <tr>
                  <td><%= batch.id %></td>
                  <td><%= batch.batch_id %></td>
                  <td><%= batch.tokens_allocated %></td>
                  <td><%= batch.tokens_remaining %></td>
                  <td><%= batch.purchase_amount || 0 %></td>
                  <td><%= batch.purchase_date ? new Date(batch.purchase_date).toLocaleString() : '-' %></td>
                  <td><%= batch.expiry_date ? new Date(batch.expiry_date).toLocaleDateString() : '-' %></td>
                  <td><span class="status-badge <%= (batch.status || '').toLowerCase() %>"><%= batch.status || '-' %></span></td>
                  <td>
                    <div class="d-flex gap-2 flex-wrap">
                      <a class="btn btn-sm btn-outline-dark rounded-pill" href="/admin/customers/<%= customer.customer_id %>/tokens?editBatchId=<%= batch.id %>">Edit</a>
                      <button
                        type="button"
                        class="btn btn-sm btn-outline-danger rounded-pill"
                        data-bs-toggle="modal"
                        data-bs-target="#deleteConfirmModal"
                        data-delete-action="/admin/customers/<%= customer.customer_id %>/tokens/<%= batch.id %>/delete"
                        data-delete-label="batch <%= batch.batch_id %>"
                      >
                        Delete
                      </button>
                    </div>
                  </td>
                </tr>
              <% }) %>
            </tbody>
            </table>
          </div>
        </div>
      </section>
      <%- include("../partials/delete-modal") %>
    <%- include("../partials/admin-shell-bottom") %>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
      (() => {
        const purchaseInput = document.getElementById("purchase_date");
        const expiryInput = document.getElementById("expiry_date");

        if (!purchaseInput || !expiryInput) {
          return;
        }

        const syncExpiryDate = () => {
          if (!purchaseInput.value) {
            expiryInput.value = "";
            return;
          }

          const purchaseDate = new Date(purchaseInput.value);
          if (Number.isNaN(purchaseDate.getTime())) {
            expiryInput.value = "";
            return;
          }

          purchaseDate.setFullYear(purchaseDate.getFullYear() + 1);
          expiryInput.value = purchaseDate.toISOString().slice(0, 10);
        };

        purchaseInput.addEventListener("input", syncExpiryDate);
        purchaseInput.addEventListener("change", syncExpiryDate);
        syncExpiryDate();
      })();
    </script>
    <%- include("../partials/toast", { toast }) %>
  </body>
</html>
