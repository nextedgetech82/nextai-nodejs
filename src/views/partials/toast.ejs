<% if (toast && toast.message) { %>
  <div class="toast-container position-fixed top-0 end-0 p-3 admin-toast-container">
    <div
      class="toast admin-toast text-bg-<%= toast.type === 'danger' ? 'danger' : toast.type === 'warning' ? 'warning' : 'success' %> border-0"
      role="alert"
      aria-live="assertive"
      aria-atomic="true"
      data-bs-delay="2600"
    >
      <div class="d-flex">
        <div class="toast-body"><%= toast.message %></div>
        <button
          type="button"
          class="btn-close btn-close-white me-2 m-auto"
          data-bs-dismiss="toast"
          aria-label="Close"
        ></button>
      </div>
    </div>
  </div>
  <script>
    document.addEventListener("DOMContentLoaded", () => {
      const toastElement = document.querySelector(".admin-toast");
      if (!toastElement || !window.bootstrap) {
        return;
      }

      window.bootstrap.Toast.getOrCreateInstance(toastElement).show();
    });
  </script>
<% } %>
